# ============================================================
# VoteCloud production environment
# Copy to .env.production for Docker, and copy the same values
# into Railway/Vercel dashboards as needed. Never commit secrets.
# ============================================================

# Runtime
NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# Public URLs
# Backend API base domain, used by email templates if needed.
BACKEND_URL=https://api.votecloud.example
# Frontend domain. This is also the strict CORS origin.
FRONTEND_URL=https://votecloud.example
# CRA frontend variable for Vercel.
REACT_APP_API_URL=https://api.votecloud.example/api

# Database and cache
MONGO_URI=mongodb://mongo:27017/votecloud
REDIS_URL=redis://redis:6379

# Organization auth. Use long random values generated by a password manager.
JWT_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Voter invitation links. Changing this invalidates existing invitation links.
VOTER_INVITE_SECRET=replace-with-long-random-voter-invite-secret
VOTER_INVITE_TTL=14d

# Blockchain provider and deployer/operator wallet.
# For Amoy testnet:
RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY
POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY
# For Polygon mainnet:
POLYGON_MAINNET_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
# Hardhat deploy scripts accept PRIVATE_KEY. The backend uses ADMIN_PRIVATE_KEY.
PRIVATE_KEY=0xreplace_with_deployer_private_key
ADMIN_PRIVATE_KEY=0xreplace_with_operator_private_key
# Polygonscan verification API key.
POLYGONSCAN_API_KEY=replace-with-polygonscan-api-key

# Contract addresses are generated into backend/src/config/contracts.json
# and frontend/src/config/contracts.json by npm run deploy:amoy/deploy:polygon.
BLOCKCHAIN_INDEXER_ENABLED=true
BLOCKCHAIN_INDEXER_SCAN_MS=30000

# Email SMTP. Resend example: SMTP_HOST=smtp.resend.com, SMTP_USER=resend.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
SMTP_PASS=re_replace_with_resend_key
EMAIL_FROM=VoteCloud <noreply@votecloud.example>
REMINDER_JOB_ENABLED=true
REMINDER_JOB_INTERVAL_MS=3600000

# Stripe subscriptions
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRO_PRICE_ID=price_replace_pro_monthly
STRIPE_BUSINESS_PRICE_ID=price_replace_business_monthly

# Optional deployment tuning
DEPLOY_CONFIRMATIONS=2
VERIFY_DELAY_MS=30000
CREATE_DEFAULT_ELECTION=false
DEFAULT_ELECTION_NAME=VoteCloud Demo Election
DEFAULT_CANDIDATES=Alice,Bob
DEFAULT_DURATION_SECS=604800
