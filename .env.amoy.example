# ============================================================
# VoteCloud Polygon Amoy deployment variables
# Copy this file to .env locally. Never commit .env.
# ============================================================

# Polygon Amoy RPC from Alchemy, Infura, or QuickNode.
POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY

# Test wallet private key used only for deployment/operator actions.
# Do not paste a real private key into chat or commit it to Git.
PRIVATE_KEY=0xreplace_with_test_wallet_private_key
ADMIN_PRIVATE_KEY=0xreplace_with_same_or_operator_private_key

# Optional: verify contracts on https://amoy.polygonscan.com
POLYGONSCAN_API_KEY=replace_with_polygonscan_api_key

# Deployment tuning.
DEPLOY_CONFIRMATIONS=2
VERIFY_DELAY_MS=30000
CREATE_DEFAULT_ELECTION=false

