# ============================================================
# ZK-Voting Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# â”€â”€ Ethereum â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Local Hardhat node (default)
RPC_URL=http://127.0.0.1:8545

# Testnet (Sepolia)
# RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Admin wallet private key (Hardhat account #0 for local dev)
# NEVER commit a real private key to version control
ADMIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# â”€â”€ Backend â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Admin authentication token (change this!)
ADMIN_TOKEN=super-secret-admin-token-change-me

# Organization auth tokens (change these in every environment)
JWT_SECRET=change-me-access-token-secret
JWT_REFRESH_SECRET=change-me-refresh-token-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Voter invitation links
VOTER_INVITE_SECRET=change-me-voter-invite-secret
VOTER_INVITE_TTL=14d

# Email SMTP
# Resend example:
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxx
# EMAIL_FROM=VoteCloud <noreply@your-domain.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=VoteCloud <no-reply@votecloud.local>

# Automatic reminders 24h before election close
REMINDER_JOB_ENABLED=true
REMINDER_JOB_INTERVAL_MS=3600000

# Blockchain event indexer
BLOCKCHAIN_INDEXER_ENABLED=true
BLOCKCHAIN_INDEXER_SCAN_MS=30000

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=

# Frontend URL (CORS whitelist)
FRONTEND_URL=http://localhost:3000

# â”€â”€ MongoDB â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
MONGO_URI=mongodb://localhost:27017/zk-voting

# â”€â”€ Frontend â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
REACT_APP_API_URL=http://localhost:3001/api

# Optional: Etherscan API key for contract verification
# ETHERSCAN_API_KEY=YOUR_KEY

